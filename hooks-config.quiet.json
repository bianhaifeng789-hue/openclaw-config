{
  "hooks": [
    {
      "event": "PreToolUse",
      "matcher": { "toolName": "*" },
      "command": "node ~/.openclaw/workspace-dispatcher/impl/bin/dangling-tool-patcher.js status",
      "timeout": 3000,
      "description": "Check dangling tool calls before tool execution"
    },
    {
      "event": "PreToolUse",
      "matcher": { "toolName": "sessions_spawn" },
      "command": "node ~/.openclaw/workspace-dispatcher/impl/bin/subagent-limiter.js status",
      "timeout": 3000,
      "description": "Check subagent limit before spawn"
    },
    {
      "event": "PreToolUse",
      "matcher": { "toolName": "read|edit|write" },
      "command": "python3 ~/.openclaw/hooks/block-secrets.py",
      "timeout": 5000,
      "description": "Block access to .env and credentials files"
    },
    {
      "event": "PreToolUse",
      "matcher": { "toolName": "exec" },
      "command": "bash ~/.openclaw/hooks/block-dangerous-commands.sh",
      "timeout": 3000,
      "description": "Block dangerous bash commands (rm -rf, etc)"
    },
    {
      "event": "PostToolUse",
      "matcher": { "toolName": "*" },
      "command": "node ~/.openclaw/workspace-dispatcher/impl/bin/tool-error-handler.js status",
      "timeout": 3000,
      "description": "Handle tool errors after execution"
    },
    {
      "event": "Stop",
      "matcher": {},
      "command": "bash ~/.openclaw/hooks/end-of-turn.sh",
      "timeout": 3000,
      "description": "Light quality gates at end of turn"
    }
  ],
  "enabled": true,
  "version": "1.3.0-quiet",
  "description": "Quiet mode: keep safety, reduce noise and post-processing"
}
