    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "claude-code",
    "patterns",
    "utilities",
    "agent-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/openclaw"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
}