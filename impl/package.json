{
  "name": "@openclaw/claude-code-patterns",
  "version": "1.0.0",
  "description": "239 Claude Code patterns integrated for OpenClaw",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "skills-converted"
  ],
  "scripts": {
