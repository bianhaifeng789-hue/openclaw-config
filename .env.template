# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# After installing dependencies, also install Playwright browsers:
#   npm install playwright
#   npx playwright install chromium

# --- API Configuration (REQUIRED) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
HARNESS_MODEL=gpt-4o

# Alternative Providers:
# OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Ollama (local): OPENAI_BASE_URL=http://localhost:11434/v1
# Anthropic: OPENAI_BASE_URL=https://api.anthropic.com/v1

# --- Workspace ---
HARNESS_WORKSPACE=./workspace

# --- Harness Tuning (optional) ---
# These thresholds control the harness loop behavior

# Token Budgets
COMPRESS_THRESHOLD=80000    # Trigger context compaction when tokens > this
RESET_THRESHOLD=150000     # Trigger context reset when tokens > this

# Harness Loop
MAX_HARNESS_ROUNDS=5        # Max build→evaluate rounds
PASS_THRESHOLD=7.0         # Score threshold to pass (out of 10)

# Agent Limits
MAX_AGENT_ITERATIONS=500   # Max tool iterations per agent run
                           # NOTE: Use high ceiling here; TimeBudgetMiddleware handles real stop
MAX_TOOL_ERRORS=5          # Consecutive tool errors before abort

# --- Profile-specific overrides (optional) ---
# Format: PROFILE_<PROFILE_NAME>_<KEY>
# Example for terminal profile:
# PROFILE_TERMINAL_PASS_THRESHOLD=8.0
# PROFILE_TERMINAL_MAX_ROUNDS=3

# Example for swe-bench profile:
# PROFILE_SWE_BENCH_TASK_BUDGET=1800    # 30 min total
# PROFILE_SWE_BENCH_BUILDER_BUDGET=900  # 15 min for builder

# --- Time Budgets (optional) ---
# Override default time allocations (seconds)
# TASK_BUDGET=3600          # Total time for task (overrides per-profile)
# PLANNER_BUDGET=300        # Time for planner agent
# BUILDER_BUDGET=2700       # Time for builder agent
# EVALUATOR_BUDGET=600      # Time for evaluator agent

# --- Middleware thresholds (optional) ---
# LOOP_FILE_EDIT_THRESHOLD=4           # File edits before loop warning
# LOOP_COMMAND_REPEAT_THRESHOLD=3      # Command repeats before loop warning
# TASK_TRACKING_NUDGE_AFTER=4          # Tool calls before tracking nudge
# TIME_WARN_THRESHOLD=0.60             # Fraction of budget for warning
# TIME_CRITICAL_THRESHOLD=0.85         # Fraction of budget for critical

# --- Playwright (optional) ---
# PLAYWRIGHT_TIMEOUT=15000             # Browser navigation timeout (ms)
# PLAYWRIGHT_HEADLESS=true             # Run browser headless
# DEV_SERVER_PORT=5173                 # Default dev server port
# DEV_SERVER_STARTUP_WAIT=8            # Seconds to wait for dev server

# --- Logging (optional) ---
# LOG_LEVEL=INFO                       # INFO, DEBUG, WARNING, ERROR
# LOG_VERBOSE=false                    # Enable verbose logging