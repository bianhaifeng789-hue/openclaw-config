{
  "hooks": [
    {
      "event": "PreToolUse",
      "matcher": { "toolName": "*" },
      "command": "node ~/.openclaw/workspace-dispatcher/impl/bin/dangling-tool-patcher.js status",
      "timeout": 3000,
      "description": "Check dangling tool calls before tool execution"
    },
    {
      "event": "PreToolUse",
      "matcher": { "toolName": "sessions_spawn" },
      "command": "node ~/.openclaw/workspace-dispatcher/impl/bin/subagent-limiter.js status",
      "timeout": 3000,
      "description": "Check subagent limit before spawn"
    },
    {
      "event": "PreToolUse",
      "matcher": { "toolName": "read|edit|write" },
      "command": "python3 ~/.openclaw/hooks/block-secrets.py",
      "timeout": 5000,
      "description": "Block access to .env and credentials files"
    },
    {
      "event": "PreToolUse",
      "matcher": { "toolName": "exec" },
      "command": "bash ~/.openclaw/hooks/block-dangerous-commands.sh",
      "timeout": 3000,
      "description": "Block dangerous bash commands (rm -rf, etc)"
    },
    {
      "event": "PostToolUse",
      "matcher": { "toolName": "*" },
      "command": "node ~/.openclaw/workspace-dispatcher/impl/bin/tool-error-handler.js status",
      "timeout": 3000,
      "description": "Handle tool errors after execution"
    },
    {
      "event": "PostToolUse",
      "matcher": { "toolName": "edit|write" },
      "command": "bash ~/.openclaw/hooks/after-edit.sh",
      "timeout": 10000,
      "description": "Run formatters after file edits"
    },
    {
      "event": "PostModelUse",
      "matcher": { "firstExchange": true },
      "command": "node ~/.openclaw/workspace-dispatcher/impl/bin/session-startup-hook.js run",
      "timeout": 10000,
      "description": "Generate session title after first exchange"
    },
    {
      "event": "Stop",
      "matcher": {},
      "command": "bash ~/.openclaw/hooks/end-of-turn.sh",
      "timeout": 5000,
      "description": "Quality gates at end of turn"
    },
    {
      "event": "Stop",
      "matcher": {},
      "command": "node ~/.openclaw/workspace-dispatcher/impl/bin/title-generator.js status",
      "timeout": 5000,
      "description": "Generate session title on stop"
    },
    {
      "event": "Stop",
      "matcher": {},
      "command": "python3 ~/.openclaw/hooks/tts_notify.py",
      "timeout": 10000,
      "description": "TTS notification on task completion"
    }
  ],
  "enabled": true,
  "version": "1.3.0-strict",
  "description": "Strict mode: all safety and notification hooks enabled"
}
