# OpenClaw Workspace .gitignore

# Infra-only sync defaults (root-level only)
/skills/
/_imports/
/artifacts/
/harness-projects/
/benchmarks/
/.clawhub/
/.openclaw/
/state/
/tmp/
/memory/.dreams/

# 环境变量（包含 API Key）
.env
.env.local

# Trace / runtime logs
_trace_*.jsonl
*.log
*.tmp
*.bak
.tmp_*

# 测试输出
_test_output/
_screenshot.png

# 系统文件
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Node modules / cache
node_modules/
.cache/
