{
  "name": "openclaw-workspace-dispatcher",
  "version": "1.0.0",
  "description": "OpenClaw Dispatcher Agent Workspace",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests configured\" && exit 0",
    "patch:openclaw": "python3 scripts/apply-openclaw-patches.py --all",
    "patch:openclaw:check": "python3 scripts/apply-openclaw-patches.py --all --dry-run --json",
    "diag:openclaw": "./scripts/openclaw-diag-capture.sh",
    "guard:session": "python3 scripts/session-pressure-guard.py",
    "guard:session:json": "python3 scripts/session-pressure-guard.py --json"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "redis": "^5.12.1",
    "sqlite3": "^6.0.1"
  }
}
