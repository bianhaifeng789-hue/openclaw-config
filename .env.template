# OpenClaw Workspace-Dispatcher 配置模板
# 复制此文件为 .env 并填写你的配置

# ============================================
# API 配置
# ============================================

# OpenAI API Key（必填）
OPENAI_API_KEY=

# API Base URL（可选，默认 OpenAI）
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认模型（可选，默认 gpt-4o）
HARNESS_MODEL=gpt-4o

# ============================================
# Harness 配置
# ============================================

# 最大 Harness 轮数（默认 5）
MAX_HARNESS_ROUNDS=5

# Pass 阈值（默认 7.0）
PASS_THRESHOLD=7.0

# 压缩阈值（默认 80000 tokens）
COMPRESS_THRESHOLD=80000

# 重置阈值（默认 150000 tokens）
RESET_THRESHOLD=150000

# 最大 Agent 迭代次数（默认 500）
MAX_AGENT_ITERATIONS=500

# 最大工具错误次数（默认 5）
MAX_TOOL_ERRORS=5

# ============================================
# 工作空间配置
# ============================================

# 工作目录（可选，默认 ~/.openclaw/workspace-dispatcher）
# WORKSPACE=/Users/your_name/.openclaw/workspace-dispatcher

# ============================================
# Profile 配置（可选）
# ============================================

# Profile 特定配置格式: PROFILE_<NAME>_<KEY>
# 示例:
# PROFILE_TERMINAL_PASS_THRESHOLD=8.0
# PROFILE_APP_BUILDER_COMPRESS_THRESHOLD=100000

# ============================================
# 日志配置（可选）
# ============================================

# 日志级别（默认 info）
LOG_LEVEL=info

# Trace 日志（默认 true）
ENABLE_TRACE=true

# ============================================
# 说明
# ============================================

# 环境变量优先级: 环境变量 > .env 文件 > 代码默认值
# 无需修改代码，只需配置此文件即可

# 硬编码位置标注: docs/HARDCODED_LOCATIONS.md